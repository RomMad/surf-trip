{% extends 'base.html.twig' %}

{% set title = 'trips.label'|trans %}

{% block body %}
    <div class="app-page-header">
        <twig:Heading1 :title="title" />
        <twig:Button:New href="{{ path('app.trip.new') }}" />
    </div>

    <twig:Trip:Form:Search :form="form" />

    {% block trip_results %}
        <twig:Turbo:Frame id="{{ constant('App\\Turbo\\Frame\\TripFrameId::RESULTS') }}">
            <twig:ResultsCount :count="pager.nbResults" translationKey="trips.count.label" />

            {% if pager.nbResults > 0 %}
                <twig:Trip:IndexTable :trips="pager" />
                <twig:AppPagination :pager="pager" />
            {% endif %}
        </twig:Turbo:Frame>
    {% endblock %}
{% endblock %}
