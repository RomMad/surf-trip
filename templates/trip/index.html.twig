{% extends 'base.html.twig' %}

{% set title = 'trips.label'|trans %}

{% block body %}
    <div class="flex justify-between">
        <twig:Heading1 :title="title" />
        <div class="sticky top-0 self-start">
            <twig:Button:New href="{{ path('app.trip.new') }}" />
        </div>
    </div>

    <twig:Trip:Form:Search :form="form" />

    {% block trip_results %}
        <twig:Turbo:Frame id="{{ constant('App\\Turbo\\Frame\\TripFrameId::RESULTS') }}">
            <twig:ResultsCount :count="pager.nbResults" />

            {% if pager.nbResults > 0 %}
                <twig:Trip:IndexTable :trips="pager" />
                <twig:AppPagination :pager="pager" />
            {% endif %}
            <twig:Sticky>
                <twig:Button
                    as="a"
                    href="{{ path('app.trip.map', app.request.query.all) }}"
                    title="{{ 'map.help'|trans }}"
                >
                    <twig:ux:icon name="lucide:map" />
                    {{- 'map.label'|trans -}}
                </twig:Button>
            </twig:Sticky>
        </twig:Turbo:Frame>
    {% endblock %}
{% endblock %}
