{% props form %}

{{ form_start(form, {attr: {
    class: 'flex flex-col gap-4 md:grid md:grid-cols-2 lg:flex lg:flex-row',
    'data-turbo-frame': 'trip_results',
}}) }}
    <twig:Form:Query :query="form.query" />
    {{ form_row(form.location, {label_attr: {hidden: null}}) }}
    <twig:Form:Period :period="form.period" />
    {{ form_row(form.requiredLevels, {attr: {class: 'w-64 min-w-48'}, label_attr: {hidden: null}}) }}
{{ form_end(form) }}
