{% props form %}

{{ form_start(form, {attr: {
    class: 'flex flex-col md:flex-row gap-4',
    'data-controller': 'auto-submit',
    'data-auto-submit-delay-value': 300,
    'data-action': 'input->auto-submit#submit change->auto-submit#submit',
    'data-turbo-frame': 'trip_results',
}}) }}
    <twig:Form:Query :query="form.query" />
    <twig:Form:Period :period="form.period" />
    {{ form_row(form.requiredLevels, {attr: {class: 'min-w-64'}, label_attr: {hidden: null}}) }}
    {{ form_row(form.location, {label_attr: {hidden: null}}) }}

    {{ form_rest(form) }}
{{ form_end(form) }}
