{# @prop string title Translation key for card section title #}
{# @prop string|null icon Optional icon name to display next to the title #}
{%- props title, icon = null -%}

<div class="{{ ('app-card ' ~ attributes.render('class'))|tailwind_merge }}">
    <div class="app-card-header">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 flex items-center gap-1">
            {% if icon %}
                <twig:ux:icon name="{{ icon }}" />
            {% endif %}
            {{- title|trans -}}
        </h3>
    </div>
    <div class="app-card-content">
        {%- block content %}{% endblock -%}
    </div>
</div>
