{%- props form, button_label = 'save.label' -%}

{{ form_errors(form) }}

{{ form_start(form, {attr: {class: 'space-y-4'}}) }}
    {{ form_row(form.spot) }}
    <div class="gap-4 grid grid-cols-1 sm:grid-cols-2">
        {{ form_row(form.date) }}
        <div class="gap-4 grid grid-cols-2">
            {{ form_row(form.startTime) }}
            {{ form_row(form.durationMinutes) }}
        </div>
    </div>
    <div class="app-form-grid-2">
        {{ form_row(form.trip) }}
        {{ form_row(form.board) }}
    </div>
    {{ form_row(form.rating) }}
    {{ form_row(form.objective) }}
    {{ form_row(form.comment) }}

    <twig:Button:Save :label="button_label" />
{{ form_end(form) }}
