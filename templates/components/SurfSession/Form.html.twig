{%- props form, button_label = 'save.label' -%}

{{ form_errors(form) }}

{{ form_start(form, {attr: {class: 'space-y-4'}}) }}
    <div class="app-form-grid-2">
        {{ form_row(form.spot) }}
        {{ form_row(form.board) }}
    </div>

    <div class="app-form-grid-2">
        {{ form_row(form.startAt) }}
        {{ form_row(form.endAt) }}
    </div>

    {{ form_row(form.rating) }}
    {{ form_row(form.objective) }}
    {{ form_row(form.comment) }}

    <twig:Button:Save :label="button_label" />
{{ form_end(form) }}
