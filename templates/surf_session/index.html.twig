{% extends 'base.html.twig' %}

{% set title = 'surf_sessions.label'|trans %}

{% block body %}
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
        <twig:Heading1 :title="title" />

        <twig:Button as="a" href="{{ path('app.surf_session.new') }}" id="new_session_btn">
            <twig:ux:icon name="lucide:plus" />
            {{- 'create_new.label'|trans -}}
        </twig:Button>
    </div>

    {% if pager.nbResults == 0 %}
        <p class="text-muted-foreground">{{ 'no_records_found.label'|trans }}</p>
    {% else %}
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
            {% for session in pager %}
                <twig:SurfSession:Card :session="session" />
            {% endfor %}
        </div>

        <twig:AppPagination :pager="pager" />
    {% endif %}
{% endblock %}
