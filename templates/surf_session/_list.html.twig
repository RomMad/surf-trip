{% for surf_session in pager %}
    <twig:SurfSession:Card :surf_session="surf_session" />
{% endfor %}

{% if pager.hasNextPage %}
    <twig:Turbo:Frame
        id="{{ constant('App\\Turbo\\Frame\\SurfSessionFrameId::LIST') }}"
        loading="lazy"
        src="{{ path(app.current_route, app.request.query.all|merge({page: pager.nextPage})) }}"
    >
        <twig:Spinner />
    </twig:Turbo:Frame>
{% endif %}
