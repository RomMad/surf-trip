{% extends 'base.html.twig' %}

{% set title = 'security.reset_password.reset.title'|trans %}

{% block container_class %}app-centered-container{% endblock %}

{% block body %}
    <twig:Heading1 :title="title" />

    {{ form_start(form) }}
        {{ form_row(form.plainPassword) }}

        <twig:Button type="submit" class="w-full">
            {{- 'security.reset_password.reset.submit'|trans -}}
        </twig:Button>
    {{ form_end(form) }}
{% endblock %}
