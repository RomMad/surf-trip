{% extends 'base.html.twig' %}

{% set title = 'security.registration.title'|trans %}

{% block container_class %}app-centered-container{% endblock %}

{% block body %}
    <twig:Heading1 :title="title" />

    {{ form_errors(form) }}

    {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
        {{ form_rest(form) }}

        <twig:Button type="submit" class="w-full">
            {{- 'register.label'|trans -}}
        </twig:Button>
    {{ form_end(form) }}
{% endblock %}
