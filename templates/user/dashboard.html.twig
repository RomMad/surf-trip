{% extends 'base.html.twig' %}

{% set title = 'dashboard.label'|trans %}
{% set kpis = stats.kpis %}

{% block body %}
    <section class="mb-8 space-y-3">
        <twig:Heading1 :title="title" />
        <p class="text-slate-500">
            {{- 'dashboard.summary'|trans -}}
        </p>
    </section>

    <section class="grid gap-6">
        <section class="grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-5">
            <twig:Dashboard:Card:Kpi label="kpis.total_trips.label" :value="kpis.totalTrips" />
            <twig:Dashboard:Card:Kpi label="kpis.trips_this_year.label" :value="kpis.tripsThisYear" />
            <twig:Dashboard:Card:Kpi label="kpis.total_sessions.label" :value="kpis.totalSessions" />
            <twig:Dashboard:Card:Kpi label="kpis.sessions_this_year.label" :value="kpis.sessionsThisYear" />
            <twig:Dashboard:Card:Kpi
                label="kpis.average_session_rating.label"
                value="{{ kpis.averageSessionRating is null ? '-' : kpis.averageSessionRating|number_format(1, '.', ' ') }}"
            />
        </section>

        <section class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]">
            <twig:Dashboard:Card:MonthlySessions
                :chart="charts.monthly_sessions"
                :monthlySessions="stats.monthlySessions"
            />
            <twig:Dashboard:Card:TopSpots
                :chart="charts.top_spots"
                :spots="stats.topSpots"
            />
        </section>
        <section>
            <twig:Dashboard:Card:YearlyActivity
                :chart="charts.yearly_activity"
                :yearlyActivity="stats.yearlyActivity"
            />
        </section>
    </section>
{% endblock %}
